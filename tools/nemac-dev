#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -d "$SCRIPT_DIR/.git" ]; then
    NEMAC_DIR="$SCRIPT_DIR"
elif [ -d "$SCRIPT_DIR/../.git" ]; then
    NEMAC_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
else
    NEMAC_DIR="/opt/nemac-de"
fi
NEMAC_VERSION="1.0"
NEMAC_REPO="lyrka-meow/testtt"
KWIN_VERSION="5.27.11"
KWIN_PREFIX="/opt/nemac-de/kwin"
LOG_DIR="${NEMAC_DIR}/logs"
STAGING_DIR="${NEMAC_DIR}/.nemac-staging"
RELEASES_DIR="${NEMAC_DIR}/releases"
TARBALL_NAME="nemac-de-${NEMAC_VERSION}-x86_64.tar.gz"

BUILD_ORDER=(
    "kwin"
    "core/libnemac"
    "apps/nemacui"
    "core/core"
    "plugins/kwin-plugins"
    "plugins/qt-plugins"
    "ui/dock"
    "ui/statusbar"
    "apps/launcher"
    "apps/settings"
    "apps/filemanager"
    "ui/screenlocker"
    "apps/screenshot"
    "apps/terminal"
    "apps/texteditor"
    "apps/calculator"
)

BUILD_DEPS=(
    git cmake make gcc ninja
    qt5-tools extra-cmake-modules
    qt5-base qt5-declarative qt5-quickcontrols2 qt5-x11extras qt5-svg qt5-graphicaleffects
    qt5-sensors qt5-multimedia qt5-script qt5-virtualkeyboard
    kdecoration
    kwindowsystem5 kidletime5 kcoreaddons5 kconfig5 kconfigwidgets5
    kcrash5 kglobalaccel5 ki18n5 knotifications5
    kpackage5 kdeclarative5 kwayland5 kservice5 kxmlgui5 kcmutils5
    knewstuff5 kdbusaddons5 kauth5 kwidgetsaddons5 kactivities5
    libkscreen5 kio5 solid5
    polkit polkit-qt5
    networkmanager-qt5
    libqt5xdg libdbusmenu-qt5
    libcanberra
    libepoxy libxcb xcb-util xcb-util-wm xcb-util-keysyms xcb-util-image xcb-util-cursor
    libdrm mesa libxkbcommon
    wayland wayland-protocols plasma-wayland-protocols libinput lcms2
    libpulse
    bluez bluez-qt5
    freetype2 fontconfig
    xorg-server-devel
    syntax-highlighting5
    libxcrypt icu
)

print_header() {
    echo ""
    echo -e "${CYAN}${BOLD}  Nemac DE — Developer Tools${NC}"
    echo -e "${CYAN}  ═══════════════════════════${NC}"
    echo ""
}

# ─── KWIN BUILD ───
# KWin 5.27 needs: kdecoration5 (only v6 in repos), plasma-framework5 (removed from repos)
# Archives vendored in core/kwin/archives/ — no network needed
# kwayland-server merged into kwin 5.25+
# kscreenlocker disabled via cmake flag

KWIN_ARCHIVES_DIR="${NEMAC_DIR}/core/kwin/archives"
PLASMA_FW_VERSION="5.116.0"

build_kwin_sub() {
    local name="$1" src_dir="$2" prefix="$3"
    echo -e "  ${BLUE}[kwin]${NC}   ↳ $name..."
    if ! cmake -Wno-dev -DCMAKE_WARN_DEPRECATED=OFF \
        -DCMAKE_INSTALL_PREFIX="$prefix" \
        -DCMAKE_PREFIX_PATH="$prefix" \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_TESTING=OFF \
        -DKDE_INSTALL_LIBDIR=lib \
        -G Ninja \
        -S "$src_dir" -B "/tmp/nemac-kwin-build/build-${name}" \
        > "$LOG_DIR/nemac-cmake-${name}.log" 2>&1; then
        echo -e "  ${RED}✗${NC}   $name (cmake)"
        echo -e "       ${YELLOW}лог: $LOG_DIR/nemac-cmake-${name}.log${NC}"
        return 1
    fi
    if ! cmake --build "/tmp/nemac-kwin-build/build-${name}" --parallel "$(nproc)" \
        > "$LOG_DIR/nemac-build-${name}.log" 2>&1; then
        echo -e "  ${RED}✗${NC}   $name (сборка)"
        echo -e "       ${YELLOW}лог: $LOG_DIR/nemac-build-${name}.log${NC}"
        return 1
    fi
    sudo cmake --install "/tmp/nemac-kwin-build/build-${name}" > /dev/null 2>&1
    echo -e "  ${GREEN}✓${NC}   $name"
    return 0
}

build_kwin() {
    local mode="$1"  # "install" or "staging"
    local staging_dir="$2"

    local kwin_src="/tmp/nemac-kwin-build"
    rm -rf "$kwin_src"
    mkdir -p "$kwin_src"

    # Verify archives exist
    for f in "kdecoration-${KWIN_VERSION}.tar.gz" "kwin-${KWIN_VERSION}.tar.gz" "plasma-framework-${PLASMA_FW_VERSION}.tar.xz"; do
        if [ ! -f "$KWIN_ARCHIVES_DIR/$f" ]; then
            echo -e "  ${RED}✗${NC} kwin (архив не найден: $f)"
            return 1
        fi
    done

    export CMAKE_PREFIX_PATH="$KWIN_PREFIX:${CMAKE_PREFIX_PATH:-}"

    # 1. kdecoration
    tar xzf "$KWIN_ARCHIVES_DIR/kdecoration-${KWIN_VERSION}.tar.gz" -C "$kwin_src"
    build_kwin_sub "kdecoration" "$kwin_src/kdecoration-v${KWIN_VERSION}" "$KWIN_PREFIX" || { rm -rf "$kwin_src"; return 1; }

    # 2. plasma-framework
    tar xf "$KWIN_ARCHIVES_DIR/plasma-framework-${PLASMA_FW_VERSION}.tar.xz" -C "$kwin_src"
    build_kwin_sub "plasma-framework" "$kwin_src/plasma-framework-${PLASMA_FW_VERSION}" "$KWIN_PREFIX" || { rm -rf "$kwin_src"; return 1; }

    # 3. KWin
    echo -e "  ${BLUE}[kwin]${NC} Собираю KWin ${KWIN_VERSION}..."
    tar xzf "$KWIN_ARCHIVES_DIR/kwin-${KWIN_VERSION}.tar.gz" -C "$kwin_src"
    if ! cmake -Wno-dev -DCMAKE_WARN_DEPRECATED=OFF \
        -DCMAKE_INSTALL_PREFIX="$KWIN_PREFIX" \
        -DCMAKE_PREFIX_PATH="$KWIN_PREFIX" \
        -DCMAKE_BUILD_TYPE=Release \
        -DBUILD_TESTING=OFF \
        -DKWIN_BUILD_SCREENLOCKER=OFF \
        -DKDE_INSTALL_LIBDIR=lib \
        -G Ninja \
        -S "$kwin_src/kwin-v${KWIN_VERSION}" \
        -B "$kwin_src/build-kwin" \
        > "$LOG_DIR/nemac-cmake-kwin.log" 2>&1; then
        echo -e "  ${RED}✗${NC} kwin (cmake)"
        echo -e "       ${YELLOW}лог: $LOG_DIR/nemac-cmake-kwin.log${NC}"
        rm -rf "$kwin_src"; return 1
    fi
    if ! cmake --build "$kwin_src/build-kwin" --parallel "$(nproc)" \
        > "$LOG_DIR/nemac-build-kwin.log" 2>&1; then
        echo -e "  ${RED}✗${NC} kwin (сборка)"
        echo -e "       ${YELLOW}лог: $LOG_DIR/nemac-build-kwin.log${NC}"
        rm -rf "$kwin_src"; return 1
    fi

    # 4. Install
    if [ "$mode" = "install" ]; then
        sudo cmake --install "$kwin_src/build-kwin" > /dev/null 2>&1
        sudo tee /usr/bin/nemac-kwin > /dev/null << 'WRAPPER'
#!/bin/bash
export QT_PLUGIN_PATH="/opt/nemac-de/kwin/lib/qt5/plugins:/opt/nemac-de/kwin/lib/plugins:${QT_PLUGIN_PATH}"
export QML2_IMPORT_PATH="/opt/nemac-de/kwin/lib/qt5/qml:/opt/nemac-de/kwin/lib/qml:${QML2_IMPORT_PATH}"
export LD_LIBRARY_PATH="/opt/nemac-de/kwin/lib:${LD_LIBRARY_PATH}"
export XDG_DATA_DIRS="/opt/nemac-de/kwin/share:${XDG_DATA_DIRS}"
exec /opt/nemac-de/kwin/bin/kwin_x11 "$@"
WRAPPER
        sudo chmod 755 /usr/bin/nemac-kwin
    elif [ "$mode" = "staging" ]; then
        env DESTDIR="$staging_dir" cmake --install "$kwin_src/build-kwin" > "$LOG_DIR/nemac-destdir-install-kwin.log" 2>&1
        env DESTDIR="$staging_dir" cmake --install "$kwin_src/build-kdecoration" > /dev/null 2>&1
        env DESTDIR="$staging_dir" cmake --install "$kwin_src/build-plasma-framework" > /dev/null 2>&1
        mkdir -p "$staging_dir/usr/bin"
        cat > "$staging_dir/usr/bin/nemac-kwin" << 'WRAPPER'
#!/bin/bash
export QT_PLUGIN_PATH="/opt/nemac-de/kwin/lib/qt5/plugins:/opt/nemac-de/kwin/lib/plugins:${QT_PLUGIN_PATH}"
export QML2_IMPORT_PATH="/opt/nemac-de/kwin/lib/qt5/qml:/opt/nemac-de/kwin/lib/qml:${QML2_IMPORT_PATH}"
export LD_LIBRARY_PATH="/opt/nemac-de/kwin/lib:${LD_LIBRARY_PATH}"
export XDG_DATA_DIRS="/opt/nemac-de/kwin/share:${XDG_DATA_DIRS}"
exec /opt/nemac-de/kwin/bin/kwin_x11 "$@"
WRAPPER
        chmod 755 "$staging_dir/usr/bin/nemac-kwin"
    fi

    rm -rf "$kwin_src"
    return 0
}

# ─── BUILD ───

cmd_build() {
    print_header
    echo -e "${BLUE}[build]${NC} Устанавливаю зависимости для сборки..."

    mkdir -p "$LOG_DIR" "$RELEASES_DIR"

    # Filter out unavailable packages
    local safe_deps=()
    for pkg in "${BUILD_DEPS[@]}"; do
        if pacman -Si "$pkg" &>/dev/null; then
            safe_deps+=("$pkg")
        else
            echo -e "  ${YELLOW}!${NC} Пакет '$pkg' не найден, пропускаю"
        fi
    done
    sudo pacman -S --needed --noconfirm "${safe_deps[@]}" > "$LOG_DIR/nemac-deps.log" 2>&1
    echo -e "${GREEN}  ✓${NC} Зависимости установлены"

    if [ ! -d "$NEMAC_DIR/.git" ]; then
        echo -e "${RED}  Репозиторий не найден: $NEMAC_DIR${NC}"
        echo -e "  ${YELLOW}Склонируйте: git clone https://github.com/$NEMAC_REPO $NEMAC_DIR${NC}"
        exit 1
    fi

    echo -e "${BLUE}[build]${NC} Собираю компоненты..."

    local total=${#BUILD_ORDER[@]}
    local current=0
    local failed=()

    for component in "${BUILD_ORDER[@]}"; do
        current=$((current + 1))

        # KWin: download from kde.org and build separately
        if [ "$component" = "kwin" ]; then
            echo -ne "  [$current/$total] kwin (KWin ${KWIN_VERSION})...\r"
            if build_kwin "install" ""; then
                echo -e "  ${GREEN}✓${NC} [$current/$total] kwin (KWin ${KWIN_VERSION} → ${KWIN_PREFIX})"
            else
                failed+=("kwin")
            fi
            continue
        fi

        local src_dir="$NEMAC_DIR/$component"

        if [ ! -d "$src_dir" ]; then
            continue
        fi

        echo -ne "  [$current/$total] $component...\r"
        local build_dir="$src_dir/build"
        rm -rf "$build_dir"

        local log_name="${component//\//-}"
        if cmake -Wno-dev -DCMAKE_WARN_DEPRECATED=OFF -DCMAKE_INSTALL_PREFIX:PATH=/usr -S "$src_dir" -B "$build_dir" > "$LOG_DIR/nemac-cmake-${log_name}.log" 2>&1; then
            if cmake --build "$build_dir" --parallel "$(nproc)" > "$LOG_DIR/nemac-build-${log_name}.log" 2>&1; then
                sudo cmake --install "$build_dir" --prefix /usr > /dev/null 2>&1
                echo -e "  ${GREEN}✓${NC} [$current/$total] $component"
            else
                failed+=("$component")
                echo -e "  ${RED}✗${NC} [$current/$total] $component (cmake --build failed)"
            fi
        else
            failed+=("$component")
            echo -e "  ${RED}✗${NC} [$current/$total] $component (cmake failed)"
        fi
    done

    echo ""
    if [ ${#failed[@]} -gt 0 ]; then
        echo -e "${RED}  Ошибки: ${failed[*]}${NC}"
        echo -e "  ${YELLOW}Логи: $LOG_DIR/nemac-cmake-*.log, nemac-build-*.log${NC}"
    else
        echo -e "${GREEN}  Все компоненты собраны и установлены.${NC}"
    fi
}

# ─── PACKAGE ───

cmd_package() {
    print_header
    echo -e "${BLUE}[package]${NC} Собираю бинарный пакет..."

    if [ ! -d "$NEMAC_DIR/.git" ]; then
        echo -e "${RED}  Репозиторий не найден: $NEMAC_DIR${NC}"
        exit 1
    fi

    mkdir -p "$LOG_DIR" "$RELEASES_DIR"
    rm -rf "$STAGING_DIR"
    mkdir -p "$STAGING_DIR"

    # Fix permissions on build dirs left root-owned by cmd_build's sudo cmake --install
    for c in "${BUILD_ORDER[@]}"; do
        [ -d "$NEMAC_DIR/$c/build" ] && sudo chown -R "$USER:" "$NEMAC_DIR/$c/build" 2>/dev/null || true
    done

    local total=${#BUILD_ORDER[@]}
    local current=0
    local failed=()

    for component in "${BUILD_ORDER[@]}"; do
        current=$((current + 1))

        # KWin: copy from already-installed /opt/nemac-de/kwin to staging (skip full rebuild)
        if [ "$component" = "kwin" ]; then
            echo -ne "  [$current/$total] kwin...\r"
            if [ -d "$KWIN_PREFIX/bin" ]; then
                mkdir -p "$STAGING_DIR/$KWIN_PREFIX"
                cp -a "$KWIN_PREFIX/." "$STAGING_DIR/$KWIN_PREFIX/"
                mkdir -p "$STAGING_DIR/usr/bin"
                cat > "$STAGING_DIR/usr/bin/nemac-kwin" << 'WRAPPER'
#!/bin/bash
export QT_PLUGIN_PATH="/opt/nemac-de/kwin/lib/qt5/plugins:/opt/nemac-de/kwin/lib/plugins:${QT_PLUGIN_PATH}"
export QML2_IMPORT_PATH="/opt/nemac-de/kwin/lib/qt5/qml:/opt/nemac-de/kwin/lib/qml:${QML2_IMPORT_PATH}"
export LD_LIBRARY_PATH="/opt/nemac-de/kwin/lib:${LD_LIBRARY_PATH}"
export XDG_DATA_DIRS="/opt/nemac-de/kwin/share:${XDG_DATA_DIRS}"
exec /opt/nemac-de/kwin/bin/kwin_x11 "$@"
WRAPPER
                chmod 755 "$STAGING_DIR/usr/bin/nemac-kwin"
                echo -e "  ${GREEN}✓${NC} [$current/$total] kwin (скопирован из $KWIN_PREFIX)"
            else
                echo -e "  ${YELLOW}!${NC} kwin не установлен, пропускаю (запусти nemac-dev build сначала)"
            fi
            continue
        fi

        local src_dir="$NEMAC_DIR/$component"

        if [ ! -d "$src_dir" ]; then
            continue
        fi

        local build_dir="$src_dir/build"

        if [ ! -f "$build_dir/CMakeCache.txt" ]; then
            echo -e "  ${YELLOW}!${NC} $component — нет build, конфигурирую..."
            local log_name="${component//\//-}"
            if ! cmake -Wno-dev -DCMAKE_WARN_DEPRECATED=OFF -DCMAKE_INSTALL_PREFIX:PATH=/usr -S "$src_dir" -B "$build_dir" > "$LOG_DIR/nemac-cmake-${log_name}.log" 2>&1; then
                failed+=("$component")
                echo -e "  ${RED}✗${NC} $component (cmake failed)"
                continue
            fi
        fi

        local log_name="${component//\//-}"
        if ! cmake --build "$build_dir" --parallel "$(nproc)" > "$LOG_DIR/nemac-build-${log_name}.log" 2>&1; then
            failed+=("$component")
            echo -e "  ${RED}✗${NC} $component (cmake --build failed)"
            echo -e "       ${YELLOW}лог: $LOG_DIR/nemac-build-${log_name}.log${NC}"
            continue
        fi

        sudo chown -R "$USER:" "$build_dir" 2>/dev/null || true
        if ! env DESTDIR="$STAGING_DIR" cmake --install "$build_dir" --prefix /usr > "$LOG_DIR/nemac-destdir-install-${log_name}.log" 2>&1; then
            failed+=("$component")
            echo -e "  ${RED}✗${NC} $component (cmake --install DESTDIR=... failed)"
            echo -e "       ${YELLOW}лог: $LOG_DIR/nemac-destdir-install-${log_name}.log${NC}"
            continue
        fi
        echo -e "  ${GREEN}✓${NC} [$current/$total] $component"
    done

    echo -e "${BLUE}[package]${NC} Добавляю ассеты..."

    # Wallpapers (in themes/wallpapers/sources/)
    if [ -d "$NEMAC_DIR/themes/wallpapers/sources" ]; then
        mkdir -p "$STAGING_DIR/usr/share/backgrounds/nemacde"
        cp -f "$NEMAC_DIR/themes/wallpapers/sources"/*.jpg "$STAGING_DIR/usr/share/backgrounds/nemacde/" 2>/dev/null || true
    fi

    # Icons (in themes/icons/) — skip @2x to keep size down
    if [ -d "$NEMAC_DIR/themes/icons/Crule" ]; then
        mkdir -p "$STAGING_DIR/usr/share/icons/Crule"
        rsync -a --exclude='*@2x*' "$NEMAC_DIR/themes/icons/Crule/" "$STAGING_DIR/usr/share/icons/Crule/" 2>/dev/null || \
            find "$NEMAC_DIR/themes/icons/Crule" -not -path '*@2x*' | while read f; do
                rel="${f#$NEMAC_DIR/themes/icons/Crule/}"
                dst="$STAGING_DIR/usr/share/icons/Crule/$rel"
                [ -d "$f" ] && mkdir -p "$dst" || cp "$f" "$dst" 2>/dev/null
            done
        # Strip @2x entries from index.theme so it matches actual directories
        python3 -c "
import re, sys
with open('$STAGING_DIR/usr/share/icons/Crule/index.theme') as f: c=f.read()
def rm2x(m):
    dirs=[d for d in m.group(1).split(',') if '@2x' not in d]
    return 'Directories='+','.join(dirs)
c=re.sub(r'Directories=([^\n]+)',rm2x,c)
c=re.sub(r'\[[^\]]*@2x[^\]]*\][^\[]*','',c)
with open('$STAGING_DIR/usr/share/icons/Crule/index.theme','w') as f: f.write(c)
" 2>/dev/null || true
    fi

    # Cursor themes (in themes/cursor-themes/)
    if [ -d "$NEMAC_DIR/themes/cursor-themes/nemac-light" ]; then
        mkdir -p "$STAGING_DIR/usr/share/icons"
        cp -rf "$NEMAC_DIR/themes/cursor-themes/nemac-light" "$STAGING_DIR/usr/share/icons/"
        cp -rf "$NEMAC_DIR/themes/cursor-themes/nemac-dark" "$STAGING_DIR/usr/share/icons/" 2>/dev/null || true
    fi

    # GTK themes (in themes/gtk-themes/)
    if [ -d "$NEMAC_DIR/themes/gtk-themes/Nemac" ]; then
        mkdir -p "$STAGING_DIR/usr/share/themes"
        cp -rf "$NEMAC_DIR/themes/gtk-themes/Nemac" "$STAGING_DIR/usr/share/themes/"
        cp -rf "$NEMAC_DIR/themes/gtk-themes/Nemac-light" "$STAGING_DIR/usr/share/themes/" 2>/dev/null || true
        cp -rf "$NEMAC_DIR/themes/gtk-themes/Nemac-dark" "$STAGING_DIR/usr/share/themes/" 2>/dev/null || true
    fi

    # Autostart entries for DE components
    mkdir -p "$STAGING_DIR/etc/xdg/autostart"
    for svc in nemac-statusbar nemac-dock nemac-launcher nemac-notificationd nemac-settings-daemon; do
        bin="/usr/bin/$svc"
        name=$(echo "$svc" | sed 's/nemac-//' | sed 's/-/ /g' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1)) substr($i,2)} 1')
        cat > "$STAGING_DIR/etc/xdg/autostart/${svc}.desktop" << DESK
[Desktop Entry]
Type=Application
Name=$name
Exec=$bin
TryExec=$bin
OnlyShowIn=Nemac;
NoDisplay=true
X-GNOME-AutoRestart=true
DESK
    done

    # Management scripts (in tools/)
    mkdir -p "$STAGING_DIR/usr/local/bin"
    [ -f "$NEMAC_DIR/tools/nemac" ] && cp "$NEMAC_DIR/tools/nemac" "$STAGING_DIR/usr/local/bin/nemac" && chmod +x "$STAGING_DIR/usr/local/bin/nemac" || true
    [ -f "$NEMAC_DIR/tools/nemac-dev" ] && cp "$NEMAC_DIR/tools/nemac-dev" "$STAGING_DIR/usr/local/bin/nemac-dev" && chmod +x "$STAGING_DIR/usr/local/bin/nemac-dev" || true

    # Updator script
    if [ -f "$NEMAC_DIR/tools/nemac-updator" ]; then
        mkdir -p "$STAGING_DIR/usr/bin"
        cp "$NEMAC_DIR/tools/nemac-updator" "$STAGING_DIR/usr/bin/nemac-updator"
        chmod +x "$STAGING_DIR/usr/bin/nemac-updator"
    fi

    mkdir -p "$STAGING_DIR/opt/nemac-de"
    if [ -f "$NEMAC_DIR/tools/nm-diagnose" ]; then
        cp "$NEMAC_DIR/tools/nm-diagnose" "$STAGING_DIR/opt/nemac-de/nemac-diagnose.sh"
        chmod +x "$STAGING_DIR/opt/nemac-de/nemac-diagnose.sh"
    fi

    # Config files
    mkdir -p "$STAGING_DIR/etc"
    cat > "$STAGING_DIR/etc/nemac" << CONF
[General]
Version=$NEMAC_VERSION
CONF
    cat > "$STAGING_DIR/etc/nemacde" << CONF
[General]
NemacDE=true
CONF

    # Remove cutefish leftovers
    rm -f "$STAGING_DIR/usr/share/applications/cutefish-"*.desktop 2>/dev/null

    echo -e "${BLUE}[package]${NC} Создаю архив..."

    local output="$RELEASES_DIR/$TARBALL_NAME"
    cd "$STAGING_DIR"
    tar czf "$output" --owner=root --group=root .
    local size
    size=$(du -h "$output" | cut -f1)

    rm -rf "$STAGING_DIR"

    echo ""
    if [ ${#failed[@]} -gt 0 ]; then
        echo -e "${YELLOW}  Внимание: не собрались: ${failed[*]}${NC}"
    fi
    echo -e "${GREEN}  Пакет создан: $output ($size)${NC}"
    echo ""
}

# ─── PUBLISH ───

cmd_publish() {
    print_header

    if ! command -v gh &>/dev/null; then
        echo -e "${RED}  GitHub CLI (gh) не установлен.${NC}"
        echo -e "  ${YELLOW}Установить: sudo pacman -S github-cli${NC}"
        echo -e "  ${YELLOW}Авторизоваться: gh auth login${NC}"
        exit 1
    fi

    if ! gh auth status &>/dev/null; then
        echo -e "${RED}  GitHub CLI не авторизован.${NC}"
        echo -e "  ${YELLOW}Выполните: gh auth login${NC}"
        exit 1
    fi

    local tarball="$RELEASES_DIR/$TARBALL_NAME"
    if [ ! -f "$tarball" ]; then
        echo -e "${RED}  Пакет не найден: $tarball${NC}"
        echo -e "  ${YELLOW}Сначала выполните: nemac-dev package${NC}"
        exit 1
    fi

    local tag="v$NEMAC_VERSION"
    local title="Nemac DE $tag"
    local size
    size=$(du -h "$tarball" | cut -f1)

    echo -e "${BLUE}[publish]${NC} Публикую в GitHub Releases..."
    echo -e "  Репозиторий: $NEMAC_REPO"
    echo -e "  Тэг: $tag"
    echo -e "  Файл: $TARBALL_NAME ($size)"
    echo ""
    read -rp "  Продолжить? (y/N): " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "  ${YELLOW}Отменено.${NC}"
        exit 0
    fi

    if gh release view "$tag" --repo "$NEMAC_REPO" &>/dev/null; then
        echo -e "  ${YELLOW}Релиз $tag уже существует, обновляю файл...${NC}"
        gh release upload "$tag" "$tarball" --repo "$NEMAC_REPO" --clobber
    else
        gh release create "$tag" "$tarball" \
            --repo "$NEMAC_REPO" \
            --title "$title" \
            --notes "Nemac DE $tag — ready-to-install binary package for Arch Linux (x86_64)."
    fi

    echo ""
    echo -e "${GREEN}  Опубликовано: https://github.com/$NEMAC_REPO/releases/tag/$tag${NC}"
    echo ""
}

# ─── TRANSFER ───

cmd_transfer() {
    print_header
    echo -e "${BLUE}[transfer]${NC} Пакую инструменты для переноса..."

    local TRANSFER_DIR="$HOME/nemac-transfer"
    rm -rf "$TRANSFER_DIR"
    mkdir -p "$TRANSFER_DIR"

    # forge
    local TOOLS_SRC="$HOME/.local/share/forge"
    if [ -d "$TOOLS_SRC" ]; then
        cp -rf "$TOOLS_SRC" "$TRANSFER_DIR/forge"
        chmod +x "$TRANSFER_DIR/forge/"fg-* "$TRANSFER_DIR/forge/install.sh" 2>/dev/null || true
        echo -e "  ${GREEN}✓${NC} forge"
    else
        echo -e "  ${YELLOW}!${NC} forge не найден: $TOOLS_SRC"
    fi

    # project_analyzer (pa)
    local PA_SRC="$HOME/project_analyzer"
    if [ -d "$PA_SRC" ]; then
        mkdir -p "$TRANSFER_DIR/project_analyzer"
        cp -f "$PA_SRC/project_analyzer" "$TRANSFER_DIR/project_analyzer/"
        chmod +x "$TRANSFER_DIR/project_analyzer/project_analyzer"

        cat > "$TRANSFER_DIR/project_analyzer/install.sh" << 'INSTALL'
#!/bin/bash
set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
mkdir -p "$HOME/.local/bin"
cp -f "$SCRIPT_DIR/project_analyzer" "$HOME/.local/bin/project_analyzer"
chmod +x "$HOME/.local/bin/project_analyzer"
if ! grep -q 'HOME/.local/bin' "$HOME/.bashrc" 2>/dev/null; then
    echo 'export PATH="$PATH:$HOME/.local/bin"' >> "$HOME/.bashrc"
fi
echo "✓ project_analyzer установлен в ~/.local/bin/"
echo "  Выполни: source ~/.bashrc"
INSTALL
        chmod +x "$TRANSFER_DIR/project_analyzer/install.sh"
        echo -e "  ${GREEN}✓${NC} project_analyzer"
    else
        echo -e "  ${YELLOW}!${NC} project_analyzer не найден: $PA_SRC"
    fi

    echo ""
    echo -e "${GREEN}  Готово!${NC} Папка: ${BOLD}$TRANSFER_DIR${NC}"
    echo -e "  Заархивируй и кидай в тг."
    echo -e "  На новой системе: распакуй и запусти ${CYAN}bash install.sh${NC} в каждой папке."
    echo ""
}

# ─── DIAGNOSE ───

cmd_diagnose() {
    local diag="${HOME}/.local/share/forge/fg-diagnose"
    if [ -f "$diag" ]; then
        bash "$diag"
    else
        echo -e "${RED}  fg-diagnose не найден: $diag${NC}"
        exit 1
    fi
}

# ─── MENU ───

show_menu() {
    while true; do
        print_header
        echo -e "  ${GREEN}1${NC})  Собрать из исходников"
        echo -e "  ${CYAN}2${NC})  Собрать пакет (tarball)"
        echo -e "  ${BLUE}3${NC})  Опубликовать в GitHub Releases"
        echo -e "  ${YELLOW}4${NC})  Диагностика"
        echo -e "  ${GREEN}5${NC})  Перенос (transfer → ~/nemac-transfer/)"
        echo -e "  ${RED}0${NC})  Выход"
        echo ""
        read -rp "  > " choice

        case $choice in
            1) cmd_build; read -rp "  Нажмите Enter..."; ;;
            2) cmd_package; read -rp "  Нажмите Enter..."; ;;
            3) cmd_publish; read -rp "  Нажмите Enter..."; ;;
            4) cmd_diagnose; read -rp "  Нажмите Enter..."; ;;
            5) cmd_transfer; read -rp "  Нажмите Enter..."; ;;
            0) exit 0 ;;
        esac
    done
}

# ─── ENTRY POINT ───

case "${1:-}" in
    build)      cmd_build ;;
    package|pkg) cmd_package ;;
    publish|pub) cmd_publish ;;
    diagnose|diag|--diagnose) cmd_diagnose ;;
    transfer)   cmd_transfer ;;
    *)          show_menu ;;
esac
